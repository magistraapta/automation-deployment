# Copy to .env next to compose.yaml (same folder as compose.yaml).
# Compose substitutes ${VAR} in compose.yaml from this file automatically.
#
# Docker Compose builds the server DATABASE_URL from these four values (host is
# always `database` inside the stack). For `go run` on your machine, add:
#   DATABASE_URL=postgres://USER:PASS@localhost:5432/DB?sslmode=disable

POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=golang_db
